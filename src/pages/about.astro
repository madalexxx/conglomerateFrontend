---
import Layout from '../layouts/main.astro';
import { motion } from 'framer-motion';
import { Users, Target, Zap, Heart } from 'lucide-react';
---

<Layout title="About Us - Paradigm Solutions">
	<section class="py-20 md:py-32">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				<div class="text-center space-y-4 mb-16">
					<h1 class="text-4xl md:text-6xl font-bold">
						About{" "}
						<span class="bg-gradient-to-r from-purple-600 to-pink-600 dark:from-purple-400 dark:to-pink-400 bg-clip-text text-transparent">
							Paradigm Solutions
						</span>
					</h1>
					<p class="text-xl text-muted-foreground max-w-2xl mx-auto">
						We're on a mission to make secure, decentralized communications accessible to everyone
					</p>
				</div>

				<!-- Story Section -->
				<div class="prose prose-lg dark:prose-invert mx-auto mb-16">
					<h2>Our Story</h2>
					<p>
						Founded in 2024, Paradigm Solutions was established to reimagine enterprise communications.
						While existing infrastructure remained fragmented and centralized, we recognized the need for
						truly decentralized, secure communications that could scale globally.
					</p>
					<p>
						Our team of network engineers, cryptography specialists, and infrastructure architects came together
						with a shared vision: to build the most reliable communications platform on Earth. Today, we're proud
						to serve enterprises across financial services, government, and distributed organizations worldwide.
					</p>
				</div>

				<!-- Values Grid -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
					<div class="p-6 rounded-2xl border bg-card">
						<div class="inline-flex p-3 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 mb-4">
							<Target className="h-6 w-6 text-white" />
						</div>
						<h3 class="text-xl font-semibold mb-2">Our Mission</h3>
						<p class="text-muted-foreground">
							To empower developers and businesses with secure, reliable communications infrastructure that
							drives innovation and protects privacy.
						</p>
					</div>

					<div class="p-6 rounded-2xl border bg-card">
						<div class="inline-flex p-3 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 mb-4">
							<Zap className="h-6 w-6 text-white" />
						</div>
						<h3 class="text-xl font-semibold mb-2">Our Vision</h3>
						<p class="text-muted-foreground">
							A world where secure communications are accessible to all, protecting privacy and
							enabling free expression without surveillance.
						</p>
					</div>

					<div class="p-6 rounded-2xl border bg-card">
						<div class="inline-flex p-3 rounded-xl bg-gradient-to-br from-green-500 to-emerald-500 mb-4">
							<Users className="h-6 w-6 text-white" />
						</div>
						<h3 class="text-xl font-semibold mb-2">Our Team</h3>
						<p class="text-muted-foreground">
							A diverse group of cryptography experts, network engineers, and security innovators from leading tech
							companies and research institutions.
						</p>
					</div>

					<div class="p-6 rounded-2xl border bg-card">
						<div class="inline-flex p-3 rounded-xl bg-gradient-to-br from-pink-500 to-rose-500 mb-4">
							<Heart className="h-6 w-6 text-white" />
						</div>
						<h3 class="text-xl font-semibold mb-2">Our Values</h3>
						<p class="text-muted-foreground">
							Transparency, ethics, innovation, and customer success guide everything
						we do at Paradigm Solutions.
						</p>
					</div>
				</div>

				<!-- Stats -->
				<div class="grid grid-cols-3 gap-8 py-12 border-y">
					<div class="text-center">
						<div class="text-3xl md:text-4xl font-bold mb-2">50K+</div>
						<p class="text-sm text-muted-foreground">Active Users</p>
					</div>
					<div class="text-center">
						<div class="text-3xl md:text-4xl font-bold mb-2">10M+</div>
						<p class="text-sm text-muted-foreground">API Requests/Day</p>
					</div>
					<div class="text-center">
						<div class="text-3xl md:text-4xl font-bold mb-2">99.9%</div>
						<p class="text-sm text-muted-foreground">Uptime SLA</p>
					</div>
				</div>

				<!-- CTA -->
				<div class="text-center mt-16">
					<h2 class="text-2xl md:text-3xl font-bold mb-4">Join Our Journey</h2>
					<p class="text-muted-foreground mb-6">
						We're always looking for talented people to join our team
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="#" class="inline-flex items-center justify-center h-10 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors">
							View Open Positions
						</a>
						<a href="/contact" class="inline-flex items-center justify-center h-10 px-6 rounded-md border bg-background hover:bg-accent hover:text-accent-foreground transition-colors">
							Get in Touch
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
