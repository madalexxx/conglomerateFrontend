---
import '../styles/global.css';
import DocsSidebar from '@/components/DocsSidebar';
import type { DocNode } from '@/lib/doc-scanner';
import { withBase } from '@/lib/utils';

interface Props {
  title?: string;
  currentSlug?: string;
  tree?: DocNode[];
  hideSidebar?: boolean;
}

const { title = 'Documentation', currentSlug = '', tree = [], hideSidebar = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="CANOPY Consortium - CRIMSON Level Access" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} - CANOPY Consortium</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="canopy-portal">
    {/* CLASSIFIED Watermarks */}
    <div class="classified-watermark top-watermark">CLASSIFIED</div>
    <div class="classified-watermark bottom-watermark">CLASSIFIED</div>

    {/* CANOPY Header */}
    <header class="canopy-header">
      <div class="header-content">
        <div class="header-left">
          <a href={withBase('/docs')} class="canopy-logo-link">
            <div class="canopy-logo">
              <svg class="logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="logo-text">
                <div class="logo-main">CANOPY CONSORTIUM</div>
                <div class="logo-sub">Per Vetitum Ad Dominium</div>
              </div>
            </div>
          </a>
        </div>
        <div class="header-right">
          <div class="clearance-badge">
            <span class="clearance-label">CLEARANCE</span>
            <span class="clearance-level">CRIMSON</span>
          </div>
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
            <svg class="sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg class="moon-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div class="canopy-container">
      <div class="flex">
        {/* Mobile sidebar toggle */}
        <input type="checkbox" id="sidebar-toggle" class="peer hidden" />

        {/* Sidebar */}
        {!hideSidebar && (
          <>
            <aside class="canopy-sidebar">
              <nav class="sidebar-nav">
                <DocsSidebar
                  client:load
                  tree={tree}
                  currentSlug={currentSlug}
                />
              </nav>
            </aside>

            {/* Mobile menu button */}
            <label for="sidebar-toggle" class="mobile-menu-btn">
              <button class="menu-btn-inner">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
              </button>
            </label>
          </>
        )}

        {/* Main content */}
        <main class={hideSidebar ? "canopy-main-full" : "canopy-main"}>
          <div class="content-wrapper">
            {/* Breadcrumb */}
            <div class="breadcrumb">
              <a href={withBase('/docs')} class="breadcrumb-link">ARCHIVE INDEX</a>
              {currentSlug && (
                <>
                  <span class="breadcrumb-sep">/</span>
                  <span class="breadcrumb-current">{title}</span>
                </>
              )}
            </div>

            {/* Page title */}
            <h1 class="page-title">{title}</h1>

            {/* Content */}
            <div class="document-content">
              <slot />
            </div>
          </div>
        </main>
      </div>
    </div>

    {/* Footer */}
    <footer class="canopy-footer">
      <div class="footer-content">
        <div class="footer-text">
                    <p class="footer-nav">
                      <a href={withBase('/')} class="footer-home-link">← Return to Paradigm Solutions</a>
                    </p>
          <p class="footer-copyright">
            © 2026 Mad Alex and the Carnival of Calamity
          </p>
          <p class="footer-license">
            Licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer" class="footer-link">CC BY-NC-SA 4.0</a>
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Theme toggle functionality
      const themeToggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      // Check for saved theme preference or default to 'light'
      const currentTheme = localStorage.getItem('theme') || 'light';
      html.classList.toggle('dark', currentTheme === 'dark');

      themeToggle?.addEventListener('click', () => {
        html.classList.toggle('dark');
        const theme = html.classList.contains('dark') ? 'dark' : 'light';
        localStorage.setItem('theme', theme);
      });
    </script>

    <style is:global>
      /* CANOPY Portal Styling */
      .canopy-portal {
        font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
        @apply bg-slate-50 text-slate-900;
      }

      .dark .canopy-portal {
        @apply bg-slate-950 text-slate-100;
      }

      /* CLASSIFIED Watermarks */
      .classified-watermark {
        position: fixed;
        left: 50%;
        transform: translateX(-50%) rotate(-15deg);
        font-family: 'JetBrains Mono', monospace;
        font-size: 8rem;
        font-weight: 700;
        letter-spacing: 0.5rem;
        color: rgba(220, 38, 38, 0.03);
        pointer-events: none;
        z-index: 0;
        user-select: none;
      }

      .dark .classified-watermark {
        color: rgba(220, 38, 38, 0.05);
      }

      .top-watermark {
        top: 15%;
      }

      .bottom-watermark {
        bottom: 15%;
        transform: translateX(-50%) rotate(15deg);
      }

      /* Header */
      .canopy-header {
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 2px solid;
        @apply bg-slate-100 border-slate-300;
      }

      .dark .canopy-header {
        @apply bg-slate-900 border-slate-700;
      }

      .header-content {
        max-width: 100%;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .header-left {
        display: flex;
        align-items: center;
      }

      .canopy-logo-link {
        text-decoration: none;
        transition: opacity 0.2s;
      }

      .canopy-logo-link:hover {
        opacity: 0.8;
      }

      .canopy-logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .logo-icon {
        width: 2rem;
        height: 2rem;
        @apply text-red-600;
      }

      .dark .logo-icon {
        @apply text-red-500;
      }

      .logo-text {
        display: flex;
        flex-direction: column;
      }

      .logo-main {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        @apply text-slate-900;
      }

      .dark .logo-main {
        @apply text-slate-100;
      }

      .logo-sub {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.625rem;
        font-weight: 400;
        letter-spacing: 0.05em;
        @apply text-slate-500;
      }

      .dark .logo-sub {
        @apply text-slate-400;
      }

      .header-right {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }

      .clearance-badge {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        font-family: 'JetBrains Mono', monospace;
      }

      .clearance-label {
        font-size: 0.625rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        @apply text-slate-500;
      }

      .dark .clearance-label {
        @apply text-slate-400;
      }

      .clearance-level {
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        @apply text-red-600;
      }

      .dark .clearance-level {
        @apply text-red-500;
      }

      .theme-toggle {
        padding: 0.5rem;
        border-radius: 0.375rem;
        border: 1px solid;
        cursor: pointer;
        transition: all 0.2s;
        @apply bg-transparent border-slate-300 text-slate-700;
      }

      .dark .theme-toggle {
        @apply border-slate-700 text-slate-300;
      }

      .theme-toggle:hover {
        @apply bg-slate-200;
      }

      .dark .theme-toggle:hover {
        @apply bg-slate-800;
      }

      .theme-toggle svg {
        width: 1.25rem;
        height: 1.25rem;
      }

      .sun-icon {
        display: none;
      }

      .dark .sun-icon {
        display: block;
      }

      .moon-icon {
        display: block;
      }

      .dark .moon-icon {
        display: none;
      }

      /* Container */
      .canopy-container {
        min-height: calc(100vh - 5rem);
        position: relative;
      }

      /* Sidebar */
      .canopy-sidebar {
        position: fixed;
        left: 0;
        top: 5rem;
        bottom: 0;
        width: 16rem;
        border-right: 1px solid;
        overflow-y: auto;
        z-index: 40;
        @apply bg-slate-100 border-slate-300;
      }

      .dark .canopy-sidebar {
        @apply bg-slate-900 border-slate-700;
      }

      @media (max-width: 1024px) {
        .canopy-sidebar {
          position: fixed;
          inset: 0;
          top: 5rem;
          transform: translateX(-100%);
          transition: transform 0.3s;
        }

        #sidebar-toggle:checked ~ .canopy-sidebar {
          transform: translateX(0);
        }
      }

      .sidebar-nav {
        padding: 1.5rem;
      }

      .mobile-menu-btn {
        position: fixed;
        left: 1rem;
        top: 6rem;
        z-index: 50;
        cursor: pointer;
      }

      @media (min-width: 1024px) {
        .mobile-menu-btn {
          display: none;
        }
      }

      .menu-btn-inner {
        padding: 0.5rem;
        border-radius: 0.5rem;
        @apply bg-slate-200;
      }

      .dark .menu-btn-inner {
        @apply bg-slate-800;
      }

      .menu-btn-inner:hover {
        @apply bg-slate-300;
      }

      .dark .menu-btn-inner:hover {
        @apply bg-slate-700;
      }

      /* Main content */
      .canopy-main {
        flex: 1;
        min-height: 100vh;
        margin-left: 16rem;
      }

      .canopy-main-full {
        flex: 1;
        min-height: 100vh;
        margin-left: 0;
      }

      @media (max-width: 1024px) {
        .canopy-main {
          margin-left: 0;
        }
      }

      .content-wrapper {
        max-width: 56rem;
        margin: 0 auto;
        padding: 2rem 1rem;
        position: relative;
        z-index: 10;
      }

      @media (min-width: 1024px) {
        .content-wrapper {
          padding: 3rem 2rem;
        }
      }

      /* Breadcrumb */
      .breadcrumb {
        margin-bottom: 2rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        @apply text-slate-600;
      }

      .dark .breadcrumb {
        @apply text-slate-400;
      }

      .breadcrumb-link {
        transition: color 0.2s;
        @apply text-slate-600;
      }

      .dark .breadcrumb-link {
        @apply text-slate-400;
      }

      .breadcrumb-link:hover {
        @apply text-slate-900;
      }

      .dark .breadcrumb-link:hover {
        @apply text-slate-100;
      }

      .breadcrumb-sep {
        margin: 0 0.5rem;
      }

      .breadcrumb-current {
        @apply text-slate-900;
      }

      .dark .breadcrumb-current {
        @apply text-slate-100;
      }

      /* Page title */
      .page-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 2rem;
        letter-spacing: -0.02em;
        line-height: 1.2;
        @apply text-slate-900;
      }

      .dark .page-title {
        @apply text-slate-100;
      }

      /* Document content - Prose styling */
      .document-content {
        font-family: 'Space Grotesk', sans-serif;
        line-height: 1.75;
        @apply text-slate-800;
      }

      .dark .document-content {
        @apply text-slate-200;
      }

      .prose {
        @apply leading-relaxed;
      }

      .prose h1 {
        font-family: 'JetBrains Mono', monospace;
        font-size: 2rem;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 1rem;
        letter-spacing: -0.01em;
        @apply text-slate-900;
      }

      .dark .prose h1 {
        @apply text-slate-100;
      }

      .prose h2 {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.5rem;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 1rem;
        letter-spacing: -0.01em;
        @apply text-slate-900;
      }

      .dark .prose h2 {
        @apply text-slate-100;
      }

      .prose h3 {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.25rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
        @apply text-slate-900;
      }

      .dark .prose h3 {
        @apply text-slate-100;
      }

      .prose h4,
      .prose h5,
      .prose h6 {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 600;
        margin-top: 1rem;
        margin-bottom: 0.5rem;
        @apply text-slate-900;
      }

      .dark .prose h4,
      .dark .prose h5,
      .dark .prose h6 {
        @apply text-slate-100;
      }

      .prose p {
        margin: 1rem 0;
        @apply text-slate-800;
      }

      .dark .prose p {
        @apply text-slate-200;
      }

      .prose a {
        font-weight: 500;
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
        transition: all 0.2s;
        @apply text-red-600;
      }

      .dark .prose a {
        @apply text-red-500;
      }

      .prose a:hover {
        text-decoration-thickness: 2px;
        @apply text-red-700;
      }

      .dark .prose a:hover {
        @apply text-red-400;
      }

      .prose code {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875rem;
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
        @apply bg-slate-200 text-slate-900;
      }

      .dark .prose code {
        @apply bg-slate-800 text-slate-100;
      }

      .prose pre {
        font-family: 'JetBrains Mono', monospace;
        padding: 1rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        margin: 1rem 0;
        border: 1px solid;
        @apply bg-slate-100 border-slate-300;
      }

      .dark .prose pre {
        @apply bg-slate-900 border-slate-700;
      }

      .prose pre code {
        background: transparent;
        padding: 0;
        border-radius: 0;
      }

      .prose ul,
      .prose ol {
        margin: 1rem 0;
        padding-left: 1.5rem;
      }

      .prose li {
        margin: 0.5rem 0;
        @apply text-slate-800;
      }

      .dark .prose li {
        @apply text-slate-200;
      }

      .prose blockquote {
        border-left: 4px solid;
        padding-left: 1rem;
        margin: 1rem 0;
        font-style: italic;
        @apply border-red-600 text-slate-600;
      }

      .dark .prose blockquote {
        @apply border-red-500 text-slate-400;
      }

      .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875rem;
      }

      .prose th,
      .prose td {
        border: 1px solid;
        padding: 0.75rem 1rem;
        text-align: left;
        @apply border-slate-300;
      }

      .dark .prose th,
      .dark .prose td {
        @apply border-slate-700;
      }

      .prose th {
        font-weight: 700;
        @apply bg-slate-200 text-slate-900;
      }

      .dark .prose th {
        @apply bg-slate-800 text-slate-100;
      }

      .prose img {
        max-width: 100%;
        height: auto;
        margin: 1rem 0;
        border-radius: 0.5rem;
      }

      .prose hr {
        margin: 2rem 0;
        border: none;
        border-top: 2px solid;
        @apply border-slate-300;
      }

      .dark .prose hr {
        @apply border-slate-700;
      }

      /* Footer */
      .canopy-footer {
        border-top: 1px solid;
        margin-top: 4rem;
        padding: 2rem 0;
        @apply border-slate-300 bg-slate-100;
      }

      .dark .canopy-footer {
        @apply border-slate-700 bg-slate-900;
      }

      .footer-content {
        max-width: 56rem;
        margin: 0 auto;
        padding: 0 1rem;
      }

      @media (min-width: 1024px) {
        .footer-content {
          padding: 0 2rem;
        }

        .canopy-main .footer-content {
          margin-left: 16rem;
        }
      }

      .footer-text {
        text-align: center;
        font-family: 'Space Grotesk', sans-serif;
      }

      .footer-nav {
        font-size: 0.875rem;
        margin-bottom: 0.75rem;
      }

      .footer-home-link {
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        @apply text-slate-600;
      }

      .dark .footer-home-link {
        @apply text-slate-400;
      }

      .footer-home-link:hover {
        text-decoration: underline;
        @apply text-slate-900;
      }

      .dark .footer-home-link:hover {
        @apply text-slate-100;
      }

      .footer-copyright {
        font-size: 0.875rem;
        margin-bottom: 0.5rem;
        @apply text-slate-600;
      }

      .dark .footer-copyright {
        @apply text-slate-400;
      }

      .footer-license {
        font-size: 0.75rem;
        @apply text-slate-500;
      }

      .dark .footer-license {
        @apply text-slate-400;
      }

      .footer-link {
        font-weight: 500;
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
        transition: all 0.2s;
        @apply text-slate-700;
      }

      .dark .footer-link {
        @apply text-slate-300;
      }

      .footer-link:hover {
        @apply text-slate-900;
      }

      .dark .footer-link:hover {
        @apply text-slate-100;
      }

      /* Strong/Bold */
      .prose strong {
        font-weight: 700;
        @apply text-slate-900;
      }

      .dark .prose strong {
        @apply text-slate-100;
      }

      /* Emphasis/Italic */
      .prose em {
        font-style: italic;
      }

      /* Table of Contents Navigation */
      .toc-nav {
        margin: 2rem 0;
      }

      .toc-nav ul {
        list-style-type: none;
        padding-left: 1.5rem;
        margin: 0.5rem 0;
      }

      .toc-nav > ul {
        padding-left: 0;
      }

      .toc-nav li {
        margin: 0.5rem 0;
      }

      .toc-nav a {
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s;
        @apply text-slate-700;
      }

      .dark .toc-nav a {
        @apply text-slate-300;
      }

      .toc-nav a:hover {
        @apply text-red-600;
      }

      .dark .toc-nav a:hover {
        @apply text-red-500;
      }
    </style>
  </body>
</html>
